# Copy this file to .env and replace placeholder values

# Telegram notifications
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Session configuration
SESSION_TIMEOUT_MINUTES=30
USERS_DB_PATH=users.db
APP_PORT=8000

# Bootstrap admin user (used only if admin user does not already exist in DB)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_please

# Cloudflared configuration
CLOUDFLARED_CONFIG_PATH=/home/user/.cloudflared/config.yml
CLOUDFLARED_FALLBACK_CONFIG_PATH=/home/user/test/cloudflared/config.yml
CLOUDFLARED_TUNNEL_NAME=fastapi-tunnel
CLOUDFLARED_DNS_AUTO_ROUTE=true
CLOUDFLARED_DNS_ROUTE_TIMEOUT_SECONDS=20
CLOUDFLARED_BIN_PATH=cloudflared
CLOUDFLARED_TUNNEL_STOP_TIMEOUT_SECONDS=10
